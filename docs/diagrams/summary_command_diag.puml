@startuml
actor User
participant "Ui" as Ui<<class>>
participant "InternTrack" as InternTrack<<class>>
participant "Parser" as Parser<<class>>
participant ":SummaryCommand" as SummaryCommand<<class>>

User -> Ui : summary
Ui -> InternTrack : handleSummaryCommand()
activate InternTrack
InternTrack -> Parser : parseSummaryCommand()
activate Parser
Parser --> InternTrack
deactivate Parser

InternTrack -> SummaryCommand : execute(applications)
activate SummaryCommand
SummaryCommand --> InternTrack
deactivate SummaryCommand
InternTrack -> Ui : printSummaryReport()
deactivate InternTrack
Ui --> User
@enduml